# Database
# DATABASE_URL="postgresql://user:password@localhost:5432/finapi"
DATABASE_URL="postgresql://docker:docker@localhost:5432/finapi?schema=public"

# JWT - use at least 32 random characters
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3033
NODE_ENV=development

# CORS - comma-separated origins
ALLOWED_ORIGINS="http://localhost:3033,http://localhost:5173"
