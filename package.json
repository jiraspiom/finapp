{
  "name": "finapi",
  "version": "1.0.0",
  "description": "Financial Management API - Bun + Hono",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify --sourcemap",
    "build:compile": "bun build ./src/index.ts --outfile ./dist/server --target bun --minify --compile",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:seed": "bun run prisma/seed.ts",
    "db:studio": "bunx prisma studio",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "predeploy": "bun run db:generate && bun run build:compile",
    "build:vercel": "prisma generate && prisma migrate deploy && bun build ./src/index.ts --outdir ./dist --target bun --minify"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.1",
    "@prisma/client": "^6.1.0",
    "@types/node": "^25.6.2",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "hono": "^4.6.12",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.2",
    "ofx": "^0.5.0",
    "ofx-js": "^1.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "bun-types": "latest",
    "prisma": "^6.1.0"
  }
}